# deploy/.env.example
# Copy to deploy/.env (chmod 600) and fill in real values before running.
# deploy/.env is git-ignored and must never be committed.

# ── Host tailnet IP ──────────────────────────────────────────────────────────
# The Intel mini's Tailscale IP (100.x range).
# Obtain with: tailscale ip -4
HOST_TS_IP=

# ── cloudflared tunnel ───────────────────────────────────────────────────────
# Named tunnel token from the Cloudflare Zero Trust dashboard.
# Rotate by recreating the tunnel token in the CF dashboard.
FLEET_CF_TUNNEL_TOKEN=

# ── Beszel ───────────────────────────────────────────────────────────────────
# PocketBase users collection credentials for fleet enroll.
# These are resolved from the macOS Keychain by the fleet binary (not used by
# the compose stack directly), but listed here for operator reference.
# FLEET_BESZEL_PASSWORD=

# ── ntfy ─────────────────────────────────────────────────────────────────────
# ntfy access token for publishing alerts (fleet CLI + Beszel + Kuma).
# FLEET_NTFY_TOKEN=
